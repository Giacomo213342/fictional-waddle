<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>business.braid.polycule</id>

    <metadata_license>FSFAP</metadata_license>
    <project_license>EUPL-1.2</project_license>

    <name>&lt; polycule &gt;</name>

    <icon type="stock">business.braid.polycule</icon>
    <icon type="remote" width="48" height="48">
        https://gitlab.com/polycule_client/polycule/-/raw/main/assets/logo/logo-circle.svg
    </icon>
    <icon type="remote" width="1024" height="1024">
        https://gitlab.com/polycule_client/polycule/-/raw/main/assets/logo/logo-circle.png
    </icon>

    <summary>
        A geeky and efficient [matrix] client for power users.
    </summary>

    <description>
        <p>
            <strong>Is it usable yet ? - No. Absolutely not.</strong>
        </p>
        <p>
            As of now, it's nothing than a fancy homeserver picker - though much more stuff already happening in
            background.
        </p>
        <p>
            Beep boop and I had too much time during boring work meetings. Using this client as
            a small piece to practice some matrix related stuff.
        </p>
        <p>
            I'm especially considering to experiment with Sliding Sync and Flutter Linux-native integrations.
        </p>
        <strong>
            Features
        </strong>
        <ul>
            <li>keyboard optimized</li>
            <li>no matrix.org !</li>
            <li>fast and efficient</li>
            <li>terminal style design</li>
            <li>cross-platform</li>
        </ul>
    </description>

    <url type="homepage">https://gitlab.com/polycule_client/polycule</url>
    <url type="bugtracker">https://gitlab.com/polycule_client/polycule/-/issues</url>

    <developer id="business.braid" name="The one with the braid"/>

    <content_rating type="oars-1.1"/>

    <launchable type="desktop-id">business.braid.polycule.desktop</launchable>

    <branding>
        <color type="primary">#3F51B5</color>
    </branding>

    <categories>
        <category>Office</category>
    </categories>

    <recommends>
        <display_length compare="ge">320</display_length>
    </recommends>
    <supports>
        <control>pointing</control>
        <control>keyboard</control>
        <control>touch</control>
    </supports>

    <recommends>
        <internet>always</internet>
    </recommends>
    <requires>
        <internet>first-run</internet>
    </requires>

    <update_contact>info_AT_braid.business</update_contact>
</component>
